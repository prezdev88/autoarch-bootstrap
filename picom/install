#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../lib/utils.sh"

app_name="picom"
repo_url="https://github.com/prezdev88/picom-config.git"
temp_dir="/tmp/picom-config-setup"
target_dir="${HOME}/.config/picom"
target_file="${target_dir}/picom.conf"

log_info "Cloning picom configuration from GitHub..."
rm -rf "${temp_dir}"
git clone "${repo_url}" "${temp_dir}"

if [ $? -ne 0 ]; then
  log_error "Failed to clone repository."
  exit 1
fi

source_file="$(find "${temp_dir}" -maxdepth 3 -type f -name "picom.conf" | head -n 1)"
if [ -z "${source_file}" ]; then
  log_error "picom.conf not found in repository."
  rm -rf "${temp_dir}"
  exit 1
fi

log_info "Creating picom config directory..."
mkdir -p "${target_dir}"

if [ -f "${target_file}" ]; then
  backup_file="${target_file}.bak.$(date +%Y%m%d_%H%M%S)"
  log_warn "Backing up existing picom configuration to ${backup_file}..."
  cp "${target_file}" "${backup_file}"
fi

log_info "Installing custom picom configuration..."
cp "${source_file}" "${target_file}"

rm -rf "${temp_dir}"
log_success "Picom configuration completed."

