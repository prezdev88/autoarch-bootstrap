#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../lib/utils.sh"

app_name="yay"
log_info "Checking if $app_name is already installed..."

if command -v yay &>/dev/null; then
    log_success "$app_name is already installed."
    exit 0
fi

log_info "Installing $app_name..."

# Go to home directory
cd "$HOME"

# Remove existing folder if present to ensure clean install
if [ -d "yay" ]; then
    log_info "Removing existing yay folder..."
    rm -rf yay
fi

# Clone and build
log_info "Cloning yay repository..."
git clone https://aur.archlinux.org/yay.git

log_info "Building and installing yay..."
cd yay
makepkg -si --noconfirm

if [ $? -eq 0 ]; then
    log_success "$app_name installation completed."
else
    log_error "$app_name installation failed."
    exit 1
fi

