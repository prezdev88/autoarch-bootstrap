#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../lib/utils.sh"

app_name="dunst"
repo_url="https://github.com/prezdev88/dunst-config.git"
temp_dir="/tmp/dunst-config-setup"
target_dir="${HOME}/.config/dunst"
target_file="${target_dir}/dunstrc"

log_info "Cloning dunst configuration from GitHub..."
rm -rf "${temp_dir}"
git clone "${repo_url}" "${temp_dir}"

if [ $? -ne 0 ]; then
  log_error "Failed to clone repository."
  exit 1
fi

source_file="$(find "${temp_dir}" -maxdepth 3 -type f -name "dunstrc" | head -n 1)"
if [ -z "${source_file}" ]; then
  log_error "dunstrc not found in repository."
  rm -rf "${temp_dir}"
  exit 1
fi

log_info "Creating dunst configuration directory..."
mkdir -p "${target_dir}"

# Backup existing file if it exists
if [ -f "${target_file}" ]; then
    backup_file="${target_file}.bak.$(date +%Y%m%d_%H%M%S)"
    log_warn "Backing up existing dunstrc to ${backup_file}"
    cp "${target_file}" "${backup_file}"
fi

log_info "Installing dunst configuration..."
cp "${source_file}" "${target_file}"

rm -rf "${temp_dir}"
log_success "Dunst setup completed."

