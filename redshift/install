#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../lib/utils.sh"

app_name="redshift"
repo_url="https://github.com/prezdev88/redshift-config.git"
temp_dir="/tmp/redshift-config-setup"
target_dir="${HOME}/.config/redshift"
target_file="${target_dir}/redshift.conf"

log_info "Cloning redshift configuration from GitHub..."
rm -rf "${temp_dir}"
git clone "${repo_url}" "${temp_dir}"

if [ $? -ne 0 ]; then
  log_error "Failed to clone repository."
  exit 1
fi

source_file="$(find "${temp_dir}" -maxdepth 3 -type f -name "redshift.conf" | head -n 1)"
if [ -z "${source_file}" ]; then
  log_error "redshift.conf not found in repository."
  rm -rf "${temp_dir}"
  exit 1
fi

log_info "Creating redshift config directory..."
mkdir -p "${target_dir}"

if [ -f "${target_file}" ]; then
  backup_file="${target_file}.bak.$(date +%Y%m%d_%H%M%S)"
  log_warn "Backing up existing redshift configuration to ${backup_file}..."
  cp "${target_file}" "${backup_file}"
fi

log_info "Installing redshift configuration..."
cp "${source_file}" "${target_file}"

rm -rf "${temp_dir}"
log_success "Redshift configuration completed."

