#!/bin/bash

app_name="redshift"
app_name_fmt="\033[1;32m${app_name}\033[0m"
repo_url="https://github.com/prezdev88/redshift-config.git"
temp_dir="/tmp/redshift-config-setup"
target_dir="${HOME}/.config/redshift"
target_file="${target_dir}/redshift.conf"

echo -e "[${app_name_fmt}] Cloning redshift configuration from GitHub..."
rm -rf "${temp_dir}"
git clone "${repo_url}" "${temp_dir}"

if [ $? -ne 0 ]; then
  echo -e "[${app_name_fmt}] \033[0;31mError: Failed to clone repository.\033[0m"
  exit 1
fi

source_file="$(find "${temp_dir}" -maxdepth 3 -type f -name "redshift.conf" | head -n 1)"
if [ -z "${source_file}" ]; then
  echo -e "[${app_name_fmt}] \033[0;31mError: redshift.conf not found in repository.\033[0m"
  rm -rf "${temp_dir}"
  exit 1
fi

echo -e "[${app_name_fmt}] Creating redshift config directory..."
mkdir -p "${target_dir}"

echo -e "[${app_name_fmt}] Installing redshift configuration..."
cp "${source_file}" "${target_file}"

echo -e "[${app_name_fmt}] Deleting cloned repository from ${temp_dir}..."
rm -rf "${temp_dir}"

echo -e "[${app_name_fmt}] Redshift configuration completed."
