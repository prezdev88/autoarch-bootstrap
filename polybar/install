#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../lib/utils.sh"

app_name="polybar"
repo_url="https://github.com/prezdev88/polybar-config"
branch="thinkpad"
target_dir="$HOME/.config/polybar"

log_info "Starting installation for $app_name..."

install_from_git "$repo_url" "$target_dir" "$branch"

if [ $? -eq 0 ]; then
    log_success "$app_name setup completed successfully."
else
    log_error "$app_name setup failed."
    exit 1
fi

