#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../../lib/utils.sh"

app_name="minimal-packages"
script_dir="$(cd "$(dirname "$0")" && pwd)"

log_info "Reading minimal package list..."
declare -a packages

if [ ! -f "$script_dir/minimal" ]; then
    log_error "Package list file 'minimal' not found in $script_dir."
    exit 1
fi

while IFS= read -r line; do
    packages+=("$line")
done < "$script_dir/minimal"

log_info "Updating package database..."
yay -Sy

log_info "Installing minimal packages..."
yay -S --noconfirm "${packages[@]}"

if [ $? -eq 0 ]; then
    log_success "Minimal packages installation completed."
else
    log_error "Failed to install some packages."
    exit 1
fi

