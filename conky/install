#!/bin/bash

# Source utils.sh
source "$(dirname "$0")/../lib/utils.sh"

app_name="conky"
repo_url="https://github.com/prezdev88/conky-config.git"
temp_dir="/tmp/conky-config-setup"
target_dir="${HOME}/.config/conky"
target_file="${target_dir}/conky.conf"

log_info "Cloning conky configuration from GitHub..."
rm -rf "${temp_dir}"
git clone "${repo_url}" "${temp_dir}"

if [ $? -ne 0 ]; then
  log_error "Failed to clone repository."
  exit 1
fi

source_file="$(find "${temp_dir}" -maxdepth 3 -type f \( -name "conky.conf" -o -name ".conkyrc" \) | head -n 1)"
if [ -z "${source_file}" ]; then
  log_error "conky config file not found in repository."
  rm -rf "${temp_dir}"
  exit 1
fi

log_info "Creating conky config directory..."
mkdir -p "${target_dir}"

if [ -f "${target_file}" ]; then
  backup_file="${target_file}.bak.$(date +%Y%m%d_%H%M%S)"
  log_warn "Backing up existing conky configuration to ${backup_file}..."
  cp "${target_file}" "${backup_file}"
fi

log_info "Installing custom conky configuration..."
cp "${source_file}" "${target_file}"

rm -rf "${temp_dir}"
log_success "Conky configuration completed."

